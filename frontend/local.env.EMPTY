# Il prefisso NEXT_PUBLIC  è obbligatorio per motivi di sicurezza
NEXT_PUBLIC_IMAGE_SERVER=
NEXT_PUBLIC_CLIENT_GOOGLE_ID=

# Login social (Home): GitHub OAuth popup + callback /oauth/github/callback ; Facebook SDK
NEXT_PUBLIC_CLIENT_GITHUB_ID=
# Produzione / dominio fisso: URL completo callback (es. https://tuodominio/oauth/github/callback).
# Locale: lasciare vuoto su localhost → si usa automaticamente http://localhost:PORTA/oauth/github/callback (registra su GitHub ogni porta usata, es. :3000 e :3001).
NEXT_PUBLIC_GITHUB_OAUTH_REDIRECT_URI=
NEXT_PUBLIC_CLIENT_FACEBOOK_APP_ID=